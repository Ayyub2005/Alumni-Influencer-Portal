# ==========================================
# PHANTASMAGORIA ENVIRONMENT CONFIGURATION
# Copy this file to '.env' and populate the values below.
# DO NOT commit the actual '.env' file to version control.
# ==========================================

# ------------------------------------------
# 1. CORE SERVER CONFIGURATION
# ------------------------------------------
# The port the Node.js Express server will listen on.
PORT=3000
# Node environment. Use 'development' for local tracing, or 'production' for strict security rules.
NODE_ENV=development

# ------------------------------------------
# 2. DATABASE CONFIGURATION (MySQL / XAMPP)
# ------------------------------------------
# The connection string for the MySQL server.
DB_HOST=localhost
# The default MySQL port is 3306.
DB_PORT=3306
# Your MySQL username (default for XAMPP is 'root').
DB_USER=root
# Your MySQL password (leave blank for default XAMPP).
DB_PASS=your_mysql_password_here
# The name of the initialized database.
DB_NAME=phantasmagoria

# ------------------------------------------
# 3. CRYPTOGRAPHIC SECRETS
# ------------------------------------------
# Secret key used to sign JSON Web Tokens (JWT) for APIs.
# Generate a secure key by running: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_character_jwt_secret_here
# Secret key used to sign Express sessions (for the Admin Portal & CSRF tracking).
# Generate similarly to the JWT key above.
SESSION_SECRET=your_64_character_session_secret_here

# ------------------------------------------
# 4. NETWORK & CORS RESTRICTIONS
# ------------------------------------------
# The canonical URL pointing to your frontend (used for Email Verification and Password Reset links).
FRONTEND_URL=http://localhost:3000
# Comma-separated list of domains legally permitted to interact with the API (stops cross-site API scraping).
ALLOWED_ORIGINS=http://localhost:3000

# ------------------------------------------
# 5. EMAIL CONFIGURATION (SMTP / Nodemailer)
# ------------------------------------------
# The primary email address used to dispatch notifications (Winner, Loser, Verification).
EMAIL_USER=your.email@gmail.com
# Use an "App Password" (16 characters) if utilizing Gmail. Do NOT use your primary login password!
# Visit: Google Account -> Security -> 2-Step Verification -> App Passwords
EMAIL_PASS=your_16_character_app_password
