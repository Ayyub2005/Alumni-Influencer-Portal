# ========================================================
# Phantasmagoria Dashboard (CW2) - Environment Variables
# Copy this file to '.env' and fill in your actual values
# ========================================================

# -----------------
# 1. Server Config
# -----------------
PORT=3001
FRONTEND_URL=http://localhost:3001

# -----------------
# 2. Database Config
# -----------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
# DB_PASS=your_mysql_password_here
DB_NAME=phantasmagoria_dashboard

# -----------------
# 3. Security Config
# -----------------
# Generate a secure 64-character hex string for production sessions
# DO NOT leave this as the default string in production
SESSION_SECRET=your_secure_session_secret_hex_string_here

# -----------------
# 4. CW1 Integration
# -----------------
# URL pointing to the active Coursework 1 API
CW1_API_URL=http://localhost:3000

# Developer keys generated from CW1 Admin Panel
CW1_ANALYTICS_KEY=your_cw1_analytics_api_key_hash_here
CW1_AR_KEY=your_cw1_ar_client_api_key_hash_here

# -----------------
# 5. Email Service
# -----------------
# Google App Passwords are required if using Gmail SMTP
EMAIL_USER=your_smtp_email_address@gmail.com
EMAIL_PASS=your_16_character_app_password_here
